{
  "name": "vite-react-template",
  "version": "2.0.0",
  "private": true,
  "description": "vite-react-template",
  "keywords": [
    "monorepo",
    "react",
    "tdesign-react",
    "template",
    "typescript",
    "vite"
  ],
  "license": "MIT",
  "author": "君惜",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xinlei3166/vite-react-template.git"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "release": "yunque-release --skipBuild",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "dependencies": {
    "@ant-design/colors": "^8.0.1",
    "@loadable/component": "^5.16.7",
    "@packages/components": "workspace:*",
    "@packages/hooks": "workspace:*",
    "@packages/lib": "workspace:*",
    "@packages/styles": "workspace:*",
    "@packages/types": "workspace:*",
    "@packages/utils": "workspace:*",
    "@reduxjs/toolkit": "^2.11.2",
    "ahooks": "^3.9.7",
    "animate.css": "^4.1.1",
    "await-to-js": "^3.0.0",
    "axios": "^1.15.0",
    "classnames": "^2.5.1",
    "cos-js-sdk-v5": "^1.10.1",
    "dayjs": "^1.11.20",
    "mitt": "^3.0.1",
    "mockjs": "^1.1.0",
    "nanoid": "^5.1.9",
    "nprogress": "^0.2.0",
    "qs": "^6.15.1",
    "raven-js": "^3.27.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.1",
    "react-router-dom": "^7.14.1",
    "react-sortablejs": "^6.1.4",
    "redux": "^5.0.1",
    "redux-logger": "^4.0.0",
    "redux-undo": "^1.1.0",
    "reselect": "^5.1.1",
    "sortablejs": "^1.15.7",
    "tdesign-icons-react": "^0.6.4",
    "tdesign-react": "^1.16.8",
    "tvision-color": "^1.6.0",
    "wujie": "^1.0.29",
    "wujie-react": "^1.0.29"
  },
  "devDependencies": {
    "@types/loadable__component": "^5.13.10",
    "@types/mockjs": "^1.0.10",
    "@types/node": "^25.6.0",
    "@types/nprogress": "^0.2.3",
    "@types/prop-types": "^15.7.15",
    "@types/qs": "^6.15.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-helmet": "^6.1.11",
    "@types/react-loadable": "^5.5.11",
    "@types/redux-logger": "^3.0.13",
    "@types/sortablejs": "^1.15.9",
    "@unocss/postcss": "^66.6.8",
    "@unocss/preset-rem-to-px": "^66.6.8",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@yunquejs/release": "^0.1.9",
    "conventional-changelog-cli": "^5.0.0",
    "csstype": "^3.2.3",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "lint-staged": "^16.4.0",
    "mockjs": "^1.1.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "picocolors": "latest",
    "postcss": "^8.5.10",
    "prop-types": "^15.8.1",
    "simple-git-hooks": "latest",
    "ssh2-sftp-client": "^12.1.1",
    "tsx": "latest",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec tsx scripts/verifyCommit.ts $1"
  },
  "lint-staged": {
    "*": [
      "oxlint --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": []
    }
  }
}
